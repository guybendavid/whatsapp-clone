{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": ["server/db/migrations-drizzle/**", "server/utils/generate-image.ts"],
  "ignoreBinaries": ["vite"],
  "workspaces": {
    "client": {
      "entry": ["src/index.tsx"],
      "project": ["src/**/*.{ts,tsx}", "src/**/*.d.ts"]
    },
    "server": {
      "project": ["**/*.{ts,js}"]
    }
  }
}

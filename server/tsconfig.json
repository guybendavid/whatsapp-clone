{
  "compilerOptions": {
    "outDir": "../dist",
    "target": "esnext",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "#root/server/*": ["./*"]
    }
  }
}

{
  "name": "whatsapp-clone-server",
  "version": "1.0.0",
  "author": "Guy Ben David",
  "license": "BSD-3-Clause",
  "private": true,
  "description": "WhatsApp clone server application",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "npx tsx db/seed.ts",
    "build": "npx tsc -p tsconfig.json",
    "dev": "npx tsx watch --tsconfig tsconfig.json -r dotenv/config app.ts | pino-pretty",
    "start": "node ../dist/app.js"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.8",
    "@guybendavid/utils": "^3.0.0",
    "@apollo/server": "^5.0.0",
    "@as-integrations/express4": "^1.1.2",
    "bcrypt": "^6.0.0",
    "drizzle-orm": "^0.36.4",
    "express": "^4.22.1",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^5.14.3",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.14.1",
    "pino": "^9.6.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/pg": "^8.11.10",
    "@types/ws": "^8.5.12",
    "dotenv": "^16.5.0",
    "drizzle-kit": "^0.31.8",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0"
  }
}
